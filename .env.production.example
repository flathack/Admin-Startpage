# Admin Startpage - Production Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================
# Authentication & Security
# ============================================

# Mock mode - set to false for production LDAP
STARTPAGE_ENABLE_MOCK_AUTH=false
STARTPAGE_ENABLE_MOCK_INTEGRATIONS=false

# LDAP Configuration
STARTPAGE_LDAP_SERVER=ldaps://dc.your-domain.com
STARTPAGE_LDAP_BASE_DN=DC=your-domain,DC=com
STARTPAGE_LDAP_DOMAIN_SUFFIX=your-domain.com

# Session Configuration (in minutes)
STARTPAGE_SESSION_TTL_MINUTES=480

# Allowed Origins (comma-separated, or * for all)
STARTPAGE_ALLOWED_ORIGINS=http://your-server,https://your-server

# ============================================
# Windows Connector (Optional)
# ============================================

STARTPAGE_CONNECTOR_ENABLED=false
STARTPAGE_CONNECTOR_URL=http://startpage-connector:8090
STARTPAGE_CONNECTOR_TIMEOUT_SECONDS=10

# ============================================
# Rollout Runtime Paths (Optional)
# ============================================

# STARTPAGE_ROLLOUT_TASKS_DIR=/path/to/rollout-jobs
# STARTPAGE_ROLLOUT_NAME_MAP_DIR=/path/to/name-map
# STARTPAGE_ROLLOUT_CONTROL_DIR=/path/to/control
# STARTPAGE_ROLLOUT_STATUS_DIR=/path/to/status

# ============================================
# Logging & Audit
# ============================================

STARTPAGE_AUDIT_LOG_ENABLED=true
STARTPAGE_AUDIT_LOG_DIR=/app/data/logs

# ============================================
# Docker Network
# ============================================

# COMPOSE_PROJECT_NAME=startpage
# COMPOSE_FILE=docker-compose.yml