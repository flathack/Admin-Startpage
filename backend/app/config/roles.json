{
  "version": 2,
  "roles": {
    "viewer": {
      "description": "Nur lesen und persoenliches Dashboard nutzen.",
      "permissions": [
        "startpage.dashboard.view",
        "ad.view",
        "ad.users.read",
        "ad.computers.read",
        "ad.groups.read"
      ]
    },
    "dashboard_editor": {
      "description": "Darf persoenliche Startseiten pflegen.",
      "permissions": [
        "startpage.dashboard.view",
        "startpage.dashboard.edit",
        "ad.view",
        "ad.users.read",
        "ad.computers.read",
        "ad.groups.read"
      ]
    },
    "platform_admin": {
      "description": "Plattformzugriff auf Nutanix, Endpoint und vSphere.",
      "permissions": [
        "startpage.dashboard.view",
        "startpage.dashboard.edit",
        "ad.view",
        "ad.users.read",
        "ad.computers.read",
        "ad.groups.read",
        "ad.users.write",
        "ad.computers.write",
        "nutanix.view",
        "nutanix.vm.create",
        "nutanix.vm.delete",
        "endpoint.view",
        "vsphere.view",
        "vsphere.vm.manage",
        "rollout.view",
        "rollout.create",
        "rollout.manage",
        "rollout.start",
        "rollout.stop",
        "rollout.delete"
      ]
    },
    "citrix_admin": {
      "description": "Citrix On-Prem lesen und verwalten.",
      "permissions": [
        "startpage.dashboard.view",
        "citrix.view",
        "citrix.machines.read",
        "citrix.delivery_groups.read",
        "citrix.assign_user",
        "citrix.maintenance",
        "citrix.maintenance.enable",
        "citrix.maintenance.disable",
        "citrix.sessions.read",
        "citrix.sessions.disconnect"
      ]
    },
    "ad_admin": {
      "description": "Active Directory Verwaltung.",
      "permissions": [
        "startpage.dashboard.view",
        "ad.view",
        "ad.users.*",
        "ad.computers.*",
        "ad.groups.*",
        "ad.ous.read",
        "ad.dns.read",
        "ad.dhcp.read"
      ]
    },
    "admin": {
      "description": "Vollzugriff auf alle Module der Startpage.",
      "permissions": [
        "startpage.*",
        "ad.*",
        "nutanix.*",
        "endpoint.*",
        "vsphere.*",
        "citrix.*",
        "rollout.*"
      ]
    }
  }
}
